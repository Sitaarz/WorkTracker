{
    "version": "0.2.0",
    "configurations": [

        {
        "name": ".NET Core Launch (web)",
        "type": "coreclr",
        "request": "launch",
        "preLaunchTask": "build",
        "program": "${workspaceFolder}/backend/src/WorkTracker.API/bin/Debug/net10.0/WorkTracker.API.dll",
        "cwd": "${workspaceFolder}/backend/src/WorkTracker.API",
        "env": {
            "ASPNETCORE_ENVIRONMENT": "Development",
            "ASPNETCORE_URLS": "http://localhost:5088"
        },
        "launchSettingsProfile": "http",
        "launchSettingsFilePath": "${workspaceFolder}/backend/src/WorkTracker.API/Properties/launchSettings.json"
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}